.container {
  padding: 24rpx;
  background-color: var(--background-color);
  min-height: 100vh;
}

.page-header {
  background-color: var(--white);
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.5s ease forwards;
  text-align: center;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title::before,
.page-title::after {
  content: '';
  width: 48rpx;
  height: 2rpx;
  background-color: var(--primary-color);
  margin: 0 24rpx;
  border-radius: 1rpx;
}

.form-item {
  background-color: var(--white);
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
  animation: slideUp 0.5s ease forwards;
}

.form-item:nth-child(2) {
  animation-delay: 0.1s;
  opacity: 0;
}

.form-item:nth-child(3) {
  animation-delay: 0.2s;
  opacity: 0;
}

.form-item:nth-child(4) {
  animation-delay: 0.3s;
  opacity: 0;
}

.form-item:nth-child(5) {
  animation-delay: 0.4s;
  opacity: 0;
}

.form-item:active {
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-4rpx);
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  display: flex;
  align-items: center;
}

.form-label::before {
  content: '';
  width: 6rpx;
  height: 6rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  margin-right: 12rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 12rpx 0;
  transition: all 0.3s ease;
}

.form-input:focus {
  color: var(--primary-color);
}

.form-submit {
  margin-top: 48rpx;
  padding: 0 24rpx;
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.5s;
  opacity: 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: var(--primary-color);
  color: var(--white);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 8rpx rgba(255, 107, 53, 0.3);
  cursor: pointer;
}

.submit-btn:active {
  background-color: var(--secondary-color);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 12rpx rgba(255, 107, 53, 0.4);
}

.submit-btn:disabled {
  background-color: var(--medium-gray);
  color: var(--text-light);
  box-shadow: none;
  cursor: not-allowed;
}

.submit-btn:disabled:active {
  transform: none;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .container {
    padding: 20rpx;
  }
  
  .page-header {
    padding: 28rpx 20rpx;
    margin-bottom: 20rpx;
  }
  
  .form-item {
    padding: 28rpx 20rpx;
    margin-bottom: 12rpx;
  }
  
  .form-label {
    width: 140rpx;
  }
  
  .form-submit {
    margin-top: 40rpx;
    padding: 0 20rpx;
  }
  
  .submit-btn {
    height: 80rpx;
  }
  
  .page-title::before,
  .page-title::after {
    width: 32rpx;
    margin: 0 16rpx;
  }
}