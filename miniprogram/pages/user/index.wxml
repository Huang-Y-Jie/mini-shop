<view class="container">
  <!-- 用户信息 -->
  <view class="user-info-section">
    <view class="user-avatar">
      <image src="{{userInfo.avatar || 'https://img.icons8.com/ios-filled/100/000000/user.png'}}" class="avatar"></image>
    </view>
    <view class="user-details">
      <view class="user-name">{{userInfo.nickname || '未登录'}}</view>
      <view class="user-phone">{{userInfo.phone || '点击修改个人信息'}}</view>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="section-more" bindtap="navigateToOrderList">查看全部</text>
    </view>
    <view class="order-icons">
      <view class="order-icon-item" bindtap="navigateToOrderList" data-status="1">
        <text class="order-icon-emoji">💰</text>
        <text class="order-icon-text">待支付</text>
      </view>
      <view class="order-icon-item" bindtap="navigateToOrderList" data-status="2">
        <text class="order-icon-emoji">✅</text>
        <text class="order-icon-text">已完成</text>
      </view>
      <view class="order-icon-item" bindtap="navigateToOrderList" data-status="3">
        <text class="order-icon-emoji">❌</text>
        <text class="order-icon-text">已取消</text>
      </view>
      <view class="order-icon-item" bindtap="navigateToOrderList">
        <text class="order-icon-emoji">📋</text>
        <text class="order-icon-text">全部</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-section">
    <view class="function-item" bindtap="navigateToAddress">
      <text class="function-icon">📍</text>
      <text class="function-text">地址管理</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="contactUs">
      <text class="function-icon">📞</text>
      <text class="function-text">联系客服</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="aboutUs">
      <text class="function-icon">ℹ️</text>
      <text class="function-text">关于我们</text>
      <text class="function-arrow">›</text>
    </view>
  </view>

  <!-- 登录按钮（未登录时显示） -->
  <view wx:if="{{!userInfo.nickname}}" class="login-section">
    <button class="login-btn" bindtap="navigateToLogin">登录</button>
  </view>

  <!-- 退出登录（已登录时显示） -->
  <view wx:if="{{userInfo.nickname}}" class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <!-- 修改个人信息模态框 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="closeEditModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">修改个人信息</text>
        <text class="modal-close" bindtap="closeEditModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input class="form-input" value="{{editInfo.nickname}}" bindinput="onEditInfoChange" data-field="nickname" placeholder="请输入昵称" />
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <input class="form-input" value="{{editInfo.phone}}" bindinput="onEditInfoChange" data-field="phone" placeholder="请输入手机号" />
        </view>
        <view class="form-item">
          <text class="form-label">地址</text>
          <input class="form-input" value="{{editInfo.address}}" bindinput="onEditInfoChange" data-field="address" placeholder="请输入地址" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel-btn" bindtap="closeEditModal">取消</button>
        <button class="modal-btn confirm-btn" bindtap="saveEditInfo">保存</button>
      </view>
    </view>
  </view>
</view>