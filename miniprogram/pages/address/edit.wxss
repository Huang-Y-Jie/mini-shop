.container {
  padding-bottom: 120rpx;
  background-color: var(--background-color);
  min-height: 100vh;
}

.header {
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  background-color: var(--white);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 99;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background-color: var(--primary-color);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.form-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  background-color: var(--white);
  transition: all 0.3s ease;
  animation: slideUp 0.5s ease forwards;
  position: relative;
}

.form-item:nth-child(2) {
  animation-delay: 0.1s;
  opacity: 0;
}

.form-item:nth-child(3) {
  animation-delay: 0.2s;
  opacity: 0;
}

.form-item:nth-child(4) {
  animation-delay: 0.3s;
  opacity: 0;
}

.form-item:nth-child(5) {
  animation-delay: 0.4s;
  opacity: 0;
}

.form-item:nth-child(6) {
  animation-delay: 0.5s;
  opacity: 0;
}

.form-item:active {
  background-color: rgba(0, 0, 0, 0.05);
  transform: translateX(8rpx);
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  display: flex;
  align-items: center;
  position: relative;
}

.label::before {
  content: '';
  width: 6rpx;
  height: 6rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  margin-right: 12rpx;
}

input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 12rpx 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  box-sizing: border-box;
  min-height: 60rpx;
  display: flex;
  align-items: center;
}

textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 12rpx 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  box-sizing: border-box;
  min-height: 160rpx;
  line-height: 40rpx;
  resize: none;
}

input:focus, textarea:focus {
  background-color: rgba(255, 107, 53, 0.1);
  outline: none;
  color: var(--primary-color);
}

textarea {
  min-height: 160rpx;
  line-height: 40rpx;
  padding: 16rpx 20rpx;
  resize: none;
}

.placeholder {
  color: var(--text-light);
}

.checkbox {
  justify-content: space-between;
  align-items: center;
}

.checkbox checkbox {
  transform: scale(1.5);
  transition: all 0.3s ease;
}

.checkbox checkbox:active {
  transform: scale(1.7);
}

.checkbox-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-left: 20rpx;
}

.submit-btn {
  margin: 48rpx 24rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  background-color: var(--primary-color);
  color: var(--white);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  cursor: pointer;
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.6s;
  opacity: 0;
}

.submit-btn:active {
  background-color: var(--secondary-color);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 53, 0.4);
}

.submit-btn:disabled {
  background-color: var(--medium-gray);
  color: var(--text-light);
  box-shadow: none;
  cursor: not-allowed;
}

.submit-btn:disabled:active {
  transform: none;
}

/* 动画效果 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .header {
    padding: 28rpx 20rpx;
  }
  
  .form-item {
    padding: 24rpx 20rpx;
  }
  
  .label {
    width: 140rpx;
  }
  
  .submit-btn {
    margin: 40rpx 20rpx 0;
    height: 80rpx;
    line-height: 80rpx;
  }
  
  input, textarea {
    padding: 10rpx 16rpx;
  }
  
  textarea {
    min-height: 140rpx;
  }
}
