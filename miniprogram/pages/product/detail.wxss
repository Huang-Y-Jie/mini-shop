/* 商品图片轮播样式 */
.product-swiper {
  width: 100%;
  height: 500rpx;
  background-color: var(--background-color);
  position: relative;
}

.swiper-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.product-image:active {
  transform: scale(1.05);
}

.swiper-count {
  position: absolute;
  bottom: 32rpx;
  right: 32rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  z-index: 1;
  backdrop-filter: blur(4rpx);
}

/* 轮播指示器 */
.swiper-indicator {
  position: absolute;
  bottom: 20rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background-color: rgba(255, 255, 255, 0.5);
  margin: 0 6rpx;
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 24rpx;
  background-color: var(--white);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 商品信息样式 */
.product-info {
  background-color: var(--card-bg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-color);
  animation: fadeIn 0.5s ease forwards;
}

.price-container {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
  position: relative;
}

.product-price {
  font-size: 44rpx;
  color: var(--primary-color);
  font-weight: bold;
  margin-right: 16rpx;
  text-shadow: 0 1rpx 2rpx rgba(24, 144, 255, 0.3);
}

.product-original-price {
  font-size: 26rpx;
  color: var(--text-light);
  text-decoration: line-through;
  margin-right: 16rpx;
}

.discount-badge {
  background: var(--gradient-bg);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(24, 144, 255, 0.3);
}

.discount-text {
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.product-name {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.product-sales {
  font-size: 26rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
}

.product-stock {
  font-size: 26rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
}



/* 商品详情样式 */
.product-detail {
  background-color: var(--card-bg);
  padding: 24rpx;
  margin-bottom: 120rpx;
  box-shadow: var(--card-shadow);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-color);
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.2s;
  opacity: 0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.detail-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--gradient-bg);
  border-radius: 4rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

.detail-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.detail-image {
  width: 100%;
  margin: 24rpx 0;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.detail-text {
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

/* 底部操作栏样式 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  background-color: var(--card-bg);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -6rpx 20rpx rgba(0, 0, 0, 0.15);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  border-top: 1rpx solid var(--border-color);
  z-index: 999;
}

.bar-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 12rpx;
  border-radius: 12rpx;
}

.bar-icon:active {
  background-color: rgba(24, 144, 255, 0.1);
  transform: translateY(-4rpx);
}

.icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.icon-text {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.quantity-container {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: var(--light-gray);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-primary);
  transition: all 0.3s ease;
  cursor: pointer;
  font-weight: bold;
}

.quantity-btn:active {
  background-color: var(--primary-color);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

.quantity-input {
  width: 96rpx;
  height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  color: var(--text-primary);
  background-color: var(--white);
  border-left: 1rpx solid var(--border-color);
  border-right: 1rpx solid var(--border-color);
  font-weight: 500;
}

.bar-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  cursor: pointer;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
  margin-left: 16rpx;
  position: relative;
  overflow: hidden;
}

.bar-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s ease;
}

.bar-btn:active::before {
  left: 100%;
}

.bar-btn:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.add-cart {
  background: linear-gradient(135deg, #ffd000 0%, #ffb800 100%);
  color: var(--text-primary);
  box-shadow: 0 6rpx 16rpx rgba(255, 208, 0, 0.4);
}

.add-cart:active {
  transform: translateY(-6rpx);
  box-shadow: 0 8rpx 20rpx rgba(255, 208, 0, 0.5);
}

.buy-now {
  background: var(--gradient-bg);
  color: var(--white);
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.4);
}

.buy-now:active {
  background: var(--gradient-bg);
  transform: translateY(-6rpx);
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.5);
  opacity: 0.9;
}

/* 规格选择样式 */
.specs-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--card-bg);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
  padding: 24rpx;
  border-top: 1rpx solid var(--border-color);
  z-index: 1000;
  animation: slideUp 0.3s ease forwards;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.specs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.specs-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.specs-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: var(--light-gray);
  transition: all 0.3s ease;
  cursor: pointer;
}

.specs-close:active {
  background-color: var(--medium-gray);
  transform: scale(0.9);
}

.specs-content {
  margin-bottom: 120rpx;
}

.specs-item {
  margin-bottom: 24rpx;
}

.specs-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.specs-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.specs-option {
  padding: 12rpx 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
  cursor: pointer;
}

.specs-option.active {
  border-color: var(--primary-color);
  color: var(--primary-color);
  background-color: rgba(24, 144, 255, 0.05);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
}

.specs-option:active {
  transform: translateY(-2rpx);
}

.specs-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: var(--white);
  border-top: 1rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.specs-price {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.specs-btn {
  padding: 16rpx 48rpx;
  background: var(--gradient-bg);
  color: var(--white);
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
  box-shadow: 0 4rpx 8rpx rgba(24, 144, 255, 0.3);
}

.specs-btn:active {
  background: var(--gradient-bg);
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 12rpx rgba(24, 144, 255, 0.4);
  opacity: 0.9;
}

/* 遮罩层样式 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  animation: fadeIn 0.3s ease forwards;
}

/* 数量选择样式 */
.count-container {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.count-label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.count-control {
  display: flex;
  align-items: center;
  background-color: var(--light-gray);
  border-radius: 8rpx;
  overflow: hidden;
}

.count-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-primary);
  transition: all 0.3s ease;
  cursor: pointer;
}

.count-btn:active {
  background-color: var(--medium-gray);
  color: var(--primary-color);
}

.count-input {
  width: 80rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--white);
  border-left: 1rpx solid var(--border-color);
  border-right: 1rpx solid var(--border-color);
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .product-swiper {
    height: 400rpx;
  }
  
  .product-price {
    font-size: 36rpx;
  }
  
  .product-name {
    font-size: 28rpx;
  }
  
  .bar-btn {
    font-size: 28rpx;
    height: 72rpx;
    line-height: 72rpx;
  }
  
  .bottom-bar {
    height: 100rpx;
  }
}