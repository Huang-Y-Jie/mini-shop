.search-container {
  height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  padding: 10rpx 20rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 20rpx;
  padding: 0 20rpx;
  height: 60rpx;
}

.search-icon {
  color: #999;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.cancel-btn {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.search-result {
  padding: 20rpx;
}

.result-header {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.no-result {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #999;
}

.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-item {
  width: 48%;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.goods-image {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
}

.goods-info {
  padding: 15rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 10rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.search-history {
  padding: 20rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-header text {
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  color: #999;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
}

.history-tag {
  background-color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin: 0 10rpx 10rpx 0;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}