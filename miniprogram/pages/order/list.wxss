/* 订单状态筛选样式 */
.order-tabs {
  display: flex;
  background-color: var(--white);
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border-radius: 12rpx;
  overflow: hidden;
  margin: 16rpx;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

.tab-item:hover {
  background-color: #f5f5f5;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: bold;
  background-color: rgba(24, 144, 255, 0.05);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--gradient-bg);
  border-radius: 3rpx;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

/* 订单列表样式 */
.order-list {
  margin: 0 16rpx 20rpx;
}

.order-item {
  background-color: var(--card-bg);
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease forwards;
  border: 1rpx solid var(--border-color);
}

.order-item:active {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
  transform: translateY(-6rpx);
  border-color: var(--primary-color);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  background-color: rgba(24, 144, 255, 0.05);
}

.order-no {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.order-status {
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
}

.order-status.pending {
  color: var(--primary-color);
  background-color: rgba(24, 144, 255, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
}

.order-status.completed {
  color: #52c41a;
  background-color: rgba(82, 196, 26, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.2);
}

.order-status.cancelled {
  color: #ff4d4f;
  background-color: rgba(255, 77, 79, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.2);
}

.order-body {
  padding: 24rpx;
}

.order-goods {
  display: flex;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
  padding: 16rpx;
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.02);
}

.order-goods:active {
  background-color: rgba(24, 144, 255, 0.05);
  transform: translateX(8rpx);
}

.order-goods:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  object-fit: cover;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s ease;
}

.order-goods:active .goods-image {
  transform: scale(1.05);
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: var(--text-primary);
  line-height: 1.4;
  font-weight: 500;
}

.goods-price-count {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(24, 144, 255, 0.3);
}

.goods-count {
  font-size: 28rpx;
  color: var(--text-secondary);
  background-color: var(--light-gray);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-top: 1rpx solid var(--border-color);
  background-color: rgba(24, 144, 255, 0.05);
}

.order-total {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: flex;
  align-items: baseline;
}

.order-total::before {
  content: '合计：';
  font-size: 28rpx;
  font-weight: normal;
  margin-right: 8rpx;
}

.order-actions {
  display: flex;
}

.action-btn {
  padding: 12rpx 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-left: 12rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  white-space: nowrap;
  min-width: 120rpx;
  text-align: center;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s ease;
}

.action-btn:active::before {
  left: 100%;
}

.action-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
}

.pay-btn {
  background: var(--gradient-bg);
  color: var(--white);
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 8rpx rgba(24, 144, 255, 0.3);
}

.pay-btn:active {
  box-shadow: 0 6rpx 12rpx rgba(24, 144, 255, 0.4);
  transform: translateY(-4rpx);
  opacity: 0.9;
}

.cancel-btn {
  color: var(--text-secondary);
}

.cancel-btn:active {
  border-color: var(--text-secondary);
  background-color: rgba(102, 102, 102, 0.05);
}

.detail-btn {
  color: var(--text-secondary);
}

.detail-btn:active {
  border-color: var(--text-secondary);
  background-color: rgba(102, 102, 102, 0.05);
}

/* 空订单状态样式 */
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: var(--text-light);
  animation: fadeIn 0.5s ease forwards;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
}

.empty-state-icon {
  font-size: 120rpx;
  margin: 0 auto 32rpx;
  opacity: 0.5;
  display: block;
  animation: pulse 2s infinite ease-in-out;
}

.empty-state-text {
  font-size: 32rpx;
  margin-bottom: 16rpx;
  line-height: 1.5;
  color: var(--text-primary);
  font-weight: 500;
}

.empty-state-subtext {
  font-size: 26rpx;
  margin-bottom: 40rpx;
  color: var(--text-light);
}

.empty-state-btn {
  display: inline-block;
  padding: 20rpx 64rpx;
  background: var(--gradient-bg);
  color: var(--white);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  min-width: 240rpx;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.3);
}

.empty-state-btn:active {
  background: var(--gradient-bg);
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.4);
  opacity: 0.9;
}