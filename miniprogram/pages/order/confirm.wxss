/* 收货地址样式 */
.address-section {
  display: flex;
  align-items: center;
  background-color: var(--white);
  padding: 24rpx;
  margin: 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease forwards;
}

.address-section:active {
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-4rpx);
}

.address-icon {
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 107, 53, 0.1);
}

.icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.8;
}

.address-info {
  flex: 1;
}

.address-detail {
  font-size: 28rpx;
}

.address-name {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.address-phone {
  margin-left: 24rpx;
  color: var(--text-secondary);
}

.address-address {
  color: var(--text-secondary);
  line-height: 1.5;
}

.address-placeholder {
  color: var(--text-light);
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.address-arrow {
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.address-arrow:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.address-arrow:active .arrow {
  transform: translateX(4rpx);
  opacity: 1;
}

/* 地区选择样式 */
.region-section {
  display: flex;
  align-items: center;
  background-color: var(--white);
  padding: 24rpx;
  margin: 0 16rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.05s;
  opacity: 0;
}

.region-section:active {
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-4rpx);
}

.region-icon {
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(52, 152, 219, 0.1);
}

.region-info {
  flex: 1;
}

.region-detail {
  font-size: 28rpx;
}

.region-name {
  display: block;
  margin-bottom: 8rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.region-fee {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.region-placeholder {
  color: var(--text-light);
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.region-arrow {
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.region-arrow:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.region-arrow:active .arrow {
  transform: translateX(4rpx);
  opacity: 1;
}

/* 商品列表样式 */
.goods-section {
  background-color: var(--white);
  padding: 24rpx;
  margin: 0 16rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.1s;
  opacity: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background-color: var(--primary-color);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.goods-item {
  display: flex;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.3s ease;
}

.goods-item:active {
  transform: translateX(8rpx);
}

.goods-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  object-fit: cover;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.goods-item:active .goods-image {
  transform: scale(1.05);
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: var(--text-primary);
  line-height: 1.4;
}

.goods-price-count {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: bold;
}

.goods-count {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 订单金额样式 */
.price-section {
  background-color: var(--white);
  padding: 24rpx;
  margin: 0 16rpx 120rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.2s;
  opacity: 0;
}

.price-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  padding: 8rpx 0;
}

.price-item.total {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
  font-weight: bold;
}

.price-label {
  color: var(--text-secondary);
}

.price-value {
  color: var(--text-primary);
}

.total-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: bold;
}

/* 底部提交栏样式 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: var(--white);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  z-index: 999;
}

.total-container {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.total-amount {
  font-size: 36rpx;
  color: var(--primary-color);
  font-weight: bold;
  margin-left: 12rpx;
}

.submit-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: var(--primary-color);
  color: var(--white);
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
  box-shadow: 0 4rpx 8rpx rgba(255, 107, 53, 0.3);
}

.submit-btn:active {
  background-color: var(--secondary-color);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 12rpx rgba(255, 107, 53, 0.4);
}

.submit-btn:disabled {
  background-color: var(--medium-gray);
  color: var(--text-light);
  box-shadow: none;
  cursor: not-allowed;
}

.submit-btn:disabled:active {
  transform: none;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .address-section {
    padding: 20rpx;
    margin: 12rpx;
  }
  
  .goods-section,
  .price-section {
    padding: 20rpx;
    margin: 0 12rpx 12rpx;
  }
  
  .price-section {
    margin-bottom: 100rpx;
  }
  
  .goods-image {
    width: 120rpx;
    height: 120rpx;
  }
  
  .bottom-bar {
    height: 100rpx;
    padding: 0 20rpx;
  }
  
  .submit-btn {
    width: 200rpx;
    font-size: 28rpx;
  }
  
  .total-amount {
    font-size: 32rpx;
  }
}