/* 轮播图样式 - 现代卡片式设计 */
.swiper {
  width: calc(100% - 32rpx);
  height: 400rpx;
  margin: 16rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.swiper-item {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.swiper-item:active .swiper-image {
  transform: scale(1.08);
}

.swiper-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.1) 40%,
    rgba(0, 0, 0, 0.4) 70%,
    rgba(0, 0, 0, 0.7) 100%
  );
  z-index: 1;
}

.swiper-content {
  position: absolute;
  bottom: 48rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 2;
  color: white;
}

.swiper-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  letter-spacing: 2rpx;
  display: block;
  line-height: 1.3;
}

.swiper-subtitle {
  font-size: 26rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  opacity: 0.95;
  display: block;
  letter-spacing: 1rpx;
}

/* 自定义指示点样式 */
.swiper .wx-swiper-dots {
  bottom: 20rpx !important;
}

.swiper .wx-swiper-dot {
  width: 16rpx !important;
  height: 16rpx !important;
  background: rgba(255, 255, 255, 0.4) !important;
  border-radius: 8rpx !important;
  margin: 0 8rpx !important;
  transition: all 0.3s ease !important;
}

.swiper .wx-swiper-dot-active {
  width: 40rpx !important;
  background: rgba(255, 255, 255, 0.95) !important;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3) !important;
}

/* 分类入口样式 */
.category-section {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid var(--border-color);
  animation: fadeIn 0.5s ease forwards;
}

.category-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.category-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--gradient-bg);
  border-radius: 4rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  transition: transform 0.3s ease;
}

.category-item:active {
  transform: translateY(-4rpx);
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 16rpx;
  border-radius: 50%;
  background: var(--gradient-bg);
  padding: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.category-icon::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, rgba(255,255,255,0.3), transparent, rgba(255,255,255,0.3));
  transform: rotate(45deg);
  animation: shine 3s infinite;
  opacity: 0;
}

.category-icon:active {
  transform: scale(1.1);
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.4);
}

.category-icon-text {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  z-index: 1;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

@keyframes shine {
  0% {
    opacity: 0;
    transform: translateX(-100%) rotate(45deg);
  }
  50% {
    opacity: 0.3;
  }
  100% {
    opacity: 0;
    transform: translateX(100%) rotate(45deg);
  }
}

.category-name {
  font-size: 26rpx;
  text-align: center;
  color: var(--text-primary);
  font-weight: 500;
}

/* 热门商品样式 */
.hot-section {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid var(--border-color);
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.2s;
  opacity: 0;
}

.hot-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.hot-title text:first-child {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.hot-title text:first-child::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--gradient-bg);
  border-radius: 4rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

.more {
  font-size: 28rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
  transition: color 0.3s ease;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.more:active {
  color: var(--primary-color);
  background-color: rgba(24, 144, 255, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
}

.more::after {
  content: '→';
  margin-left: 4rpx;
  font-size: 24rpx;
  transition: transform 0.3s ease;
}

.more:active::after {
  transform: translateX(4rpx);
}

.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-item {
  width: 48%;
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease forwards;
  background-color: var(--card-bg);
  border: 1rpx solid var(--border-color);
  position: relative;
}

.goods-item:nth-child(1) {
  animation-delay: 0.3s;
  opacity: 0;
}

.goods-item:nth-child(2) {
  animation-delay: 0.4s;
  opacity: 0;
}

.goods-item:nth-child(3) {
  animation-delay: 0.5s;
  opacity: 0;
}

.goods-item:nth-child(4) {
  animation-delay: 0.6s;
  opacity: 0;
}

.goods-item:nth-child(5) {
  animation-delay: 0.7s;
  opacity: 0;
}

.goods-item:nth-child(6) {
  animation-delay: 0.8s;
  opacity: 0;
}

.goods-item:active {
  transform: translateY(-10rpx);
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.18);
  border-color: var(--primary-color);
}

.goods-image-container {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.goods-item:active .goods-image {
  transform: scale(1.08);
}

.discount-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: var(--gradient-bg);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(24, 144, 255, 0.3);
  z-index: 1;
}

.discount-text {
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.goods-info {
  padding: 20rpx;
}

.goods-name {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: var(--text-primary);
  line-height: 1.4;
  font-weight: 500;
}

.goods-price-container {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.goods-price {
  font-size: 36rpx;
  color: var(--primary-color);
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(24, 144, 255, 0.3);
  margin-right: 12rpx;
}

.goods-original-price {
  font-size: 24rpx;
  color: var(--text-light);
  text-decoration: line-through;
}

.goods-sales {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

/* 推荐商品样式 */
.recommend-section {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid var(--border-color);
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.4s;
  opacity: 0;
}

.recommend-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.recommend-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--gradient-bg);
  border-radius: 4rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

/* 加载状态样式 */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 32rpx;
  color: var(--text-secondary);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 页面容器 */
.page-container {
  padding: 16rpx;
}

/* 底部间距 */
.bottom-space {
  height: 100rpx;
}

/* 搜索框样式 */
.search-container {
  margin-bottom: 24rpx;
  animation: fadeIn 0.5s ease forwards;
  animation-delay: 0.1s;
  opacity: 0;
  padding: 0 16rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: var(--white);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border: 1rpx solid var(--border-color);
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

.search-input:active {
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.15);
  transform: translateY(-2rpx);
  border-color: var(--primary-color);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: var(--text-light);
}

.search-placeholder {
  font-size: 28rpx;
  color: var(--text-light);
  flex: 1;
}

