<view class="container">
  <view class="category-container">
    <!-- 左侧分类列表 -->
    <view class="category-left">
      <view 
        wx:for="{{categories}}" 
        wx:key="id" 
        class="category-item {{activeCategoryId == item.id ? 'active' : ''}}"
        bindtap="selectCategory" 
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>
    
    <!-- 右侧商品列表 -->
    <view class="category-right">
      <view class="goods-list">
        <view wx:for="{{categoryGoods}}" wx:key="id" class="goods-item" bindtap="navigateToDetail" data-id="{{item.id}}">
          <image src="{{item.cover_img}}" class="goods-image"></image>
          <view class="goods-info">
            <text class="goods-name">{{item.name}}</text>
            <view class="price-sales-container">
              <text class="goods-price">¥{{item.price}}</text>
              <text class="goods-sales">已售{{item.sales || 0}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 空状态 -->
      <view wx:if="{{categoryGoods.length == 0}}" class="empty-state">
        <text>该分类下暂无商品</text>
      </view>
    </view>
  </view>
</view>