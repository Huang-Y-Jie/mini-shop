/* 分类容器样式 */
.category-container {
  display: flex;
  height: 100vh;
  background-color: var(--background-color);
}

/* 左侧分类列表样式 */
.category-left {
  width: 220rpx;
  background-color: var(--white);
  border-right: 1rpx solid var(--border-color);
  overflow-y: auto;
  box-shadow: 2rpx 0 8rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.category-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 28rpx;
  border-left: 4rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
  font-weight: 500;
  width: 100%;
}

.category-item:active {
  background-color: rgba(255, 107, 53, 0.05);
}

.category-item.active {
  color: var(--primary-color);
  border-left-color: var(--primary-color);
  background-color: var(--background-color);
  font-weight: bold;
  box-shadow: -2rpx 0 8rpx rgba(255, 107, 53, 0.1);
}

.category-item.active::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 60rpx;
  background-color: var(--primary-color);
  border-radius: 0 2rpx 2rpx 0;
}

/* 右侧商品列表样式 */
.category-right {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  background-color: var(--background-color);
}

/* 分类标题样式 */
.category-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: var(--text-primary);
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-item {
  width: 48%;
  margin-bottom: 24rpx;
  background-color: var(--white);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease forwards;
}

.goods-item:nth-child(1) {
  animation-delay: 0.1s;
  opacity: 0;
}

.goods-item:nth-child(2) {
  animation-delay: 0.2s;
  opacity: 0;
}

.goods-item:nth-child(3) {
  animation-delay: 0.3s;
  opacity: 0;
}

.goods-item:nth-child(4) {
  animation-delay: 0.4s;
  opacity: 0;
}

.goods-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.12);
}

.goods-image {
  width: 100%;
  height: 240rpx;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.goods-item:active .goods-image {
  transform: scale(1.05);
}

.goods-info {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  height: 140rpx;
}

.goods-name {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: var(--text-primary);
  line-height: 1.4;
  flex: 1;
}

.price-sales-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.goods-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: bold;
}

.goods-original-price {
  font-size: 24rpx;
  color: var(--text-light);
  text-decoration: line-through;
  margin-left: 8rpx;
}

.goods-sales {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 150rpx 0;
  color: var(--text-light);
  animation: fadeIn 0.5s ease forwards;
}

.empty-state-icon {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 32rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.empty-state-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background-color: var(--primary-color);
  color: var(--white);
  border-radius: 8rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.empty-state-btn:active {
  background-color: var(--secondary-color);
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(255, 107, 53, 0.3);
}

/* 加载更多样式 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

/* 底部间距 */
.bottom-space {
  height: 100rpx;
}