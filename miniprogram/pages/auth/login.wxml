<view class="container">
  <view class="logo-section">
    <image src="https://img.icons8.com/color/96/000000/shopping-bag.png" class="logo"></image>
    <text class="title">线上商城</text>
    <text class="subtitle">欢迎登录</text>
  </view>
  
  <view class="login-section">
    <view class="login-btn" bindtap="login">
      <image src="https://img.icons8.com/color/48/000000/wechat.png" class="wechat-icon"></image>
      <text class="login-text">微信授权登录</text>
    </view>
  </view>
  
  <view class="tips-section">
    <text class="tips">登录即表示您同意</text>
    <text class="tips-link" bindtap="showAgreement">《用户协议》</text>
    <text class="tips">和</text>
    <text class="tips-link" bindtap="showPrivacy">《隐私政策》</text>
  </view>
</view>