.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f5f5;
  padding: 0 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666;
}

.login-section {
  width: 100%;
  margin-bottom: 120rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890ff;
  border-radius: 80rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
  transition: all 0.3s ease;
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(24, 144, 255, 0.4);
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.login-text {
  font-size: 36rpx;
  font-weight: 500;
  color: #fff;
}

.tips-section {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.tips-link {
  color: #1890ff;
  margin: 0 8rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.container {
  animation: fadeIn 0.8s ease forwards;
}

.logo-section {
  animation: fadeIn 0.8s ease forwards;
  animation-delay: 0.2s;
  opacity: 0;
}

.login-section {
  animation: fadeIn 0.8s ease forwards;
  animation-delay: 0.4s;
  opacity: 0;
}

.tips-section {
  animation: fadeIn 0.8s ease forwards;
  animation-delay: 0.6s;
  opacity: 0;
}